  },
  "item": [
    {
      "name": "Create Credential",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api-key",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api-key"
          ]
        }
      }
    },
    {
      "name": "Protected Data",
      "request": {
        "method": "GET",
