        ],
        "url": {
          "raw": "{{base_url}}/data",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "data"
          ]
        }
      }
    },
    {
      "name": "Usage Summary",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "x-api-key",
            "value": "{{api_key}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/usage",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "usage"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
